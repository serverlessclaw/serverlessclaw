{
  "name": "@serverlessclaw/core",
  "version": "1.0.0",
  "description": "Core engine and agent implementation for Serverless Claw.",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    "./lib/*": "./lib/*.js",
    "./agents/*": "./agents/*.js",
    "./tools/*": "./tools/*.js",
    "./handlers/*": "./handlers/*.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1010.0",
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1009.0",
    "@aws-sdk/client-codebuild": "^3.1010.0",
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/client-eventbridge": "^3.1010.0",
    "@aws-sdk/client-iot": "^3.1019.0",
    "@aws-sdk/client-iot-data-plane": "^3.1009.0",
    "@aws-sdk/client-lambda": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/client-scheduler": "^3.1010.0",
    "@aws-sdk/lib-dynamodb": "^3.1010.0",
    "@aws/run-mcp-servers-with-aws-lambda": "^0.5.0",
    "@cyanheads/git-mcp-server": "^2.10.5",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@mcp-server/google-search-mcp": "^1.0.3",
    "@kirkdeam/puppeteer-mcp-server": "^1.1.0",
    "mcp-fetch-server": "^1.1.2",
    "mcp-aws-devops-server": "^3.7.1",
    "@geunoh/s3-mcp-server": "^1.3.1",
    "@aiready/ast-mcp-server": "0.8.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents-core": "^0.8.0",
    "@serverlessclaw/integration-github": "workspace:*",
    "archiver": "^7.0.1",
    "openai": "^6.31.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "test": "vitest run",
    "test-silent": "vitest run --reporter=dot",
    "test-coverage": "vitest run --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../.prettierignore",
    "aiready": "aiready scan --threshold 80"
  }
}
