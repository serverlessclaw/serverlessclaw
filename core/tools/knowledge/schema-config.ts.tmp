    description:
      'Dispatches a technical research task. Supports single-step discovery or parallel multi-agent exploration.',
    parameters: {
      type: 'object',
      properties: {
        goal: {
          type: 'string',
          description:
            'The technical research goal or question (e.g., "Research Auth0 vs Cognito").',
