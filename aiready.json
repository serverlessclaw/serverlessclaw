{
  "$schema": "https://getaiready.dev/schema.json",
  "threshold": 75,
  "scan": {
    "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
    "exclude": [
      "**/node_modules/**",
      "**/.sst/**",
      "**/.next/**",
      "**/.aiready/**",
      "**/.opencode/**",
      "**/.kilo/**"
    ],
    "tools": [
      "pattern-detect",
      "context-analyzer",
      "naming-consistency",
      "ai-signal-clarity",
      "agent-grounding",
      "testability-index",
      "doc-drift",
      "dependency-health",
      "change-amplification",
      "contract-enforcement"
    ]
  },
  "output": {
    "format": "console",
    "showBreakdown": true,
    "saveTo": "aiready-report.json"
  },
  "scoring": {
    "profile": "agentic",
    "showBreakdown": true
  },
  "tools": {
    "pattern-detect": {
      "minSimilarity": 0.5,
      "minLines": 3,
      "minSharedTokens": 5,
      "approx": true,
      "batchSize": 500,
      "maxCandidatesPerBlock": 1000,
      "minClusterFiles": 3,
      "minClusterTokenCost": 1000,
      "includeTests": true
    },
    "context-analyzer": {
      "maxContextBudget": 200000,
      "minCohesion": 0.6,
      "maxDepth": 15,
      "maxFragmentation": 0.4,
      "focus": "all",
      "includeNodeModules": false,
      "exclude": ["packages/core/tools/index.ts"]
    },
    "naming-consistency": {
      "checkNaming": true,
      "checkPatterns": true,
      "checkArchitecture": true,
      "shortWords": ["id", "db", "ui", "ai"],
      "acceptedAbbreviations": [
        "API",
        "JSON",
        "CSV",
        "HTML",
        "CSS",
        "HTTP",
        "URL",
        "SDK",
        "CLI",
        "AI",
        "ML",
        "ID",
        "DB",
        "UI",
        "UX",
        "DOM",
        "UUID",
        "GUID",
        "DEFAULT",
        "MAX",
        "MIN",
        "config",
        "INIT",
        "SKILL",
        "ENV",
        "DEV",
        "PROD",
        "AWS",
        "S3",
        "ARN",
        "SST",
        "TTL",
        "PK",
        "SK",
        "LKG",
        "QA",
        "HITL",
        "ROI",
        "AST",
        "MCP",
        "DDB"
      ],
      "disableChecks": [
        "naming-consistency:const-uppercase-snake-case",
        "naming-consistency:function-camel-case"
      ],
      "exclude": ["**/components/ui/**", "scripts/**"]
    },
    "ai-signal-clarity": {
      "checkMagicLiterals": true,
      "checkBooleanTraps": true,
      "checkAmbiguousNames": true,
      "checkUndocumentedExports": true,
      "checkImplicitSideEffects": true,
      "checkDeepCallbacks": true,
      "checkOverloadedSymbols": true,
      "checkLargeFiles": true,
      "exclude": ["**/components/ui/**"]
    },
    "agent-grounding": {
      "maxRecommendedDepth": 5,
      "readmeStaleDays": 30,
      "additionalVagueNames": ["stuff", "misc", "temp", "test"]
    },
    "testability-index": {
      "minCoverageRatio": 0.7,
      "testPatterns": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**", "**/*.spec.ts"],
      "maxDepth": 10
    },
    "doc-drift": {
      "maxCommits": 50,
      "staleMonths": 3
    },
    "dependency-health": {
      "trainingCutoffYear": 2023
    },
    "change-amplification": {
      "exclude": ["packages/core/tools/index.ts"]
    }
  },
  "visualizer": {
    "groupingDirs": ["packages", "apps", "scripts"],
    "graph": {
      "maxNodes": 5000,
      "maxEdges": 10000
    }
  }
}
