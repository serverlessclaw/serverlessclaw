{
  "name": "@serverlessclaw/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 7777",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --config ./vitest.config.ts",
    "test-silent": "vitest run --reporter=dot --config ./vitest.config.ts",
