    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@serverlessclaw/core": "workspace:*",
    "@opennextjs/aws": "3.10.2",
    "@xyflow/react": "^12.10.1",
    "lucide-react": "^1.0.0",
    "mqtt": "^5.15.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "sst": "4.7.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
