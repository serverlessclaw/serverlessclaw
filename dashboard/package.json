    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.4",
    "raw-loader": "^4.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
