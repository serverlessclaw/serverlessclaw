{
  "name": "@claw/infra",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "test": "vitest run",
    "test-silent": "vitest run --reporter=dot --config ../vitest.config.ts",
    "test-coverage": "vitest run --coverage --config ../vitest.config.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../.prettierignore",
    "aiready": "aiready scan"
  }
}
