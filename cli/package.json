{
  "name": "@serverlessclaw/cli",
  "version": "0.1.0",
  "description": "CLI tool for managing and syncing serverlessclaw agentic stack.",
  "main": "dist/index.js",
  "bin": {
    "claw-sync": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin.js",
    "dev": "tsc -w",
    "dev": "tsc -w",
    "test": "vitest run",
    "test-silent": "vitest run --reporter=dot",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../.prettierignore",
    "aiready": "aiready scan --threshold 80"
  },
  "dependencies": {
    "@serverlessclaw/core": "workspace:*",
    "@serverlessclaw/integration-github": "workspace:*",
    "commander": "^14.0.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
