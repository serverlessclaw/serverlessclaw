{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node", "aws-lambda"]
  },
  "include": [
    "core/**/*.ts",
    "infra/**/*.ts",
    "sst.config.ts",
    ".sst/platform/config.d.ts",
    "sst-env.d.ts"
  ],
  "exclude": ["node_modules", "dashboard/src"]
}
