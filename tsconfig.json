{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "types": ["node", "aws-lambda"]
  },
  "include": [
    "core/**/*.ts",
    "infra/**/*.ts",
    "sst.config.ts",
    ".sst/platform/config.d.ts",
    "sst-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dashboard/src"
  ]
}
