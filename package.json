{
  "name": "serverlessclaw",
  "version": "1.0.14",
  "packageManager": "pnpm@10.32.1",
  "description": "A serverless implementation of OpenClaw AI agent using SST, AWS Lambda, and DynamoDB.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serverlessclaw/serverlessclaw.git"
  },
  "homepage": "https://github.com/serverlessclaw/serverlessclaw#readme",
  "bugs": {
    "url": "https://github.com/serverlessclaw/serverlessclaw/issues"
  },
  "main": "index.js",
  "scripts": {
    "test": "turbo run test",
    "test-silent": "turbo run test-silent",
    "test-coverage": "turbo run test-coverage",
    "test-e2e": "make test-e2e",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --ignore-path .prettierignore",
    "prepare": "husky",
    "type-check": "turbo run type-check",
    "format-check": "turbo run format-check",
    "check": "turbo run check",
    "gate": "turbo run gate"
  },
  "keywords": [
    "openclaw",
    "serverless",
    "sst",
    "aws",
    "lambda",
    "ai-agent"
  ],
  "author": "Peng Cao",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@aiready/ast-mcp-server": "0.1.6",
    "@opennextjs/aws": "3.9.16",
    "dotenv": "^17.3.1",
    "sst": "4.5.12",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "brace-expansion": ">=5.0.5",
      "minimatch@3.1.5>brace-expansion": "1.1.12",
      "picomatch@<3": ">=2.3.2",
      "picomatch@>=3": ">=4.0.4",
      "yaml": ">=2.8.3",
      "path-to-regexp": ">=8.4.0",
      "glob": ">=10.5.0",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "next": "16.2.2",
      "lodash": ">=4.18.1"
    }
  },
  "devDependencies": {
    "@aiready/cli": "^0.15.6",
    "@aws-sdk/client-cloudfront": "^3.1020.0",
    "@aws-sdk/client-lambda": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "^4.0.18",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
