{
  "name": "serverlessclaw",
  "version": "1.0.6",
  "description": "A serverless implementation of OpenClaw AI agent using SST, AWS Lambda, and DynamoDB.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:silent": "LOG_LEVEL=none vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"core/**/*.ts\" \"infra/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "openclaw",
    "serverless",
    "sst",
    "aws",
    "lambda",
    "ai-agent"
  ],
  "author": "Peng Cao",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1005.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1004.0",
    "@aws-sdk/client-codebuild": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-eventbridge": "^3.1004.0",
    "@aws-sdk/client-iot-data-plane": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-ssm": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@opennextjs/aws": "^3.9.16",
    "archiver": "^7.0.1",
    "lucide-react": "^0.577.0",
    "openai": "^6.27.0",
    "sst": "^4.2.2",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "{src,.}/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.5",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/ui": "^4.0.18",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
